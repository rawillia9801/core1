# Cherolee Core local/development environment example.
#
# Copy values into .env.local for local work. Do not commit .env.local.
# This file documents variable names only and intentionally contains no real
# service keys, passwords, SMTP credentials, or production customer settings.

# Supabase local/dev
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Required on Vercel for deployed login/auth and protected owner/operator routes.
# Use the matching Supabase project values in Vercel environment settings.
# Do not commit real values here.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Core local secrets
CORE_INTAKE_SECRET=

# Optional local/dev intake actor override.
# Leave blank unless a rollback-safe local intake test explicitly needs it.
CORE_INTAKE_ACTOR_PROFILE_ID=

# Email safety flags
EMAIL_PROVIDER=disabled
EMAIL_SEND_ENABLED=false
EMAIL_PREVIEW_ONLY=true

# Future Hostinger SMTP variables.
# Keep blank unless a later approved SMTP task adds preview/test-send gates,
# staging override, send logs, audit rows, and owner/admin controls.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_REPLY_TO_ADDRESS=
EMAIL_TEST_RECIPIENT=
EMAIL_STAGING_OVERRIDE_RECIPIENT=
